# Allow write access to touchbar backlight brightness for dimming/off
SUBSYSTEM=="backlight", KERNEL=="appletb_backlight", RUN+="/bin/chmod 0666 /sys/class/backlight/appletb_backlight/brightness"
SUBSYSTEM=="backlight", KERNEL=="228200000.display-pipe.0", RUN+="/bin/chmod 0666 /sys/class/backlight/228200000.display-pipe.0/brightness"
SUBSYSTEM=="backlight", KERNEL=="228600000.dsi.0", RUN+="/bin/chmod 0666 /sys/class/backlight/228600000.dsi.0/brightness"

# Allow read/write access to touchbar input device for user service
SUBSYSTEM=="input", ATTR{name}=="Touch Bar Display", MODE="0666"
